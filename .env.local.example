# ─── Supabase ─────────────────────────────────────────────────────────────────
# From supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...
SUPABASE_SERVICE_ROLE_KEY=eyJhb...   # Keep secret — never expose client-side

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...         # or sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# From Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App URL ──────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
